NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3001
# If a host Postgres already uses 5432, see README "Local Postgres on port 5432"
# — use the docker-compose override and set this to ...@localhost:5433/app.
DATABASE_URL=postgres://app:app@localhost:5432/app
